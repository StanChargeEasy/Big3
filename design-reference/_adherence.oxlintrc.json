{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "archive/site v2026-06-10 (redesign standard)/**",
              "components/brand/**",
              "components/celestial/**",
              "components/core/**",
              "pages.jsx",
              "site/**",
              "ui_kits/instagram/**",
              "ui_kits/website/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Jost|Playfair Display|Mulish))/i]",
        "message": "Font not provided by the design system. Available: Jost, Playfair Display, Mulish."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|size|pill|style|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: children, variant, size, pill, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:wine|coral|gold|ink|softWine|softCoral|softGold|outline)$/]",
        "message": "<Badge> variant must be one of 'wine' | 'coral' | 'gold' | 'ink' | 'softWine' | 'softCoral' | 'softGold' | 'outline'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Badge> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|size|uppercase|pill|full|disabled|iconLeft|iconRight|style|onClick|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: children, variant, size, uppercase, pill, full, disabled, iconLeft, iconRight, style, onClick."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|accent|gold|outline|ghost|inverse)$/]",
        "message": "<Button> variant must be one of 'primary' | 'accent' | 'gold' | 'outline' | 'ghost' | 'inverse'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|surface|elevation|border|radius|padding|style|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: children, surface, elevation, border, radius, padding, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute[name.name='surface'] > Literal[value!=/^(?:paper|cream|sand|blush|plum|wine|charcoal)$/]",
        "message": "<Card> surface must be one of 'paper' | 'cream' | 'sand' | 'blush' | 'plum' | 'wine' | 'charcoal'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute[name.name='elevation'] > Literal[value!=/^(?:none|sm|card|float|lg)$/]",
        "message": "<Card> elevation must be one of 'none' | 'sm' | 'card' | 'float' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute[name.name='radius'] > Literal[value!=/^(?:none|sm|md|lg|xl)$/]",
        "message": "<Card> radius must be one of 'none' | 'sm' | 'md' | 'lg' | 'xl'."
      },
      {
        "selector": "JSXOpeningElement[name.name='CelestialDivider'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|base|color|glyphSize|style|key|ref|className|style|children)$/]",
        "message": "<CelestialDivider> doesn't accept that prop. Declared props: variant, base, color, glyphSize, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='CelestialDivider'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:duo|trinity)$/]",
        "message": "<CelestialDivider> variant must be one of 'duo' | 'trinity'."
      },
      {
        "selector": "JSXOpeningElement[name.name='CelestialDivider'] > JSXAttribute[name.name='color'] > Literal[value!=/^(?:wine|gold|coral|ink)$/]",
        "message": "<CelestialDivider> color must be one of 'wine' | 'gold' | 'coral' | 'ink'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Eyebrow'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|color|rules|align|style|key|ref|className|style|children)$/]",
        "message": "<Eyebrow> doesn't accept that prop. Declared props: children, color, rules, align, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Eyebrow'] > JSXAttribute[name.name='color'] > Literal[value!=/^(?:coral|wine|gold|ink|muted)$/]",
        "message": "<Eyebrow> color must be one of 'coral' | 'wine' | 'gold' | 'ink' | 'muted'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Eyebrow'] > JSXAttribute[name.name='align'] > Literal[value!=/^(?:left|center)$/]",
        "message": "<Eyebrow> align must be one of 'left' | 'center'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Logo'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|height|base|style|key|ref|className|style|children)$/]",
        "message": "<Logo> doesn't accept that prop. Declared props: variant, height, base, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Logo'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:colorDark|colorLight|black|white)$/]",
        "message": "<Logo> variant must be one of 'colorDark' | 'colorLight' | 'black' | 'white'."
      },
      {
        "selector": "JSXOpeningElement[name.name='StarRating'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|max|size|gap|color|style|key|ref|className|style|children)$/]",
        "message": "<StarRating> doesn't accept that prop. Declared props: value, max, size, gap, color, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='StarRating'] > JSXAttribute[name.name='color'] > Literal[value!=/^(?:gold|coral|wine)$/]",
        "message": "<StarRating> color must be one of 'gold' | 'coral' | 'wine'."
      },
      {
        "selector": "JSXOpeningElement[name.name='TrinityMark'] > JSXAttribute > JSXIdentifier[name!=/^(?:size|base|tone|style|key|ref|className|style|children)$/]",
        "message": "<TrinityMark> doesn't accept that prop. Declared props: size, base, tone, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='TrinityMark'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:color|white|ink)$/]",
        "message": "<TrinityMark> tone must be one of 'color' | 'white' | 'ink'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ZodiacGlyph'] > JSXAttribute > JSXIdentifier[name!=/^(?:sign|color|size|style|key|ref|className|style|children)$/]",
        "message": "<ZodiacGlyph> doesn't accept that prop. Declared props: sign, color, size, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='ZodiacGlyph'] > JSXAttribute[name.name='sign'] > Literal[value!=/^(?:aries|taurus|gemini|cancer|leo|virgo|libra|scorpio|sagittarius|capricorn|aquarius|pisces|sun|moon|mercury|venus|mars|jupiter|saturn)$/]",
        "message": "<ZodiacGlyph> sign must be one of 'aries' | 'taurus' | 'gemini' | 'cancer' | 'leo' | 'virgo' | 'libra' | 'scorpio' | 'sagittarius' | 'capricorn' | 'aquarius' | 'pisces' | 'sun' | 'moon' | 'mercury' | 'venus' | 'mars' | 'jupiter' | 'saturn'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ZodiacGlyph'] > JSXAttribute[name.name='color'] > Literal[value!=/^(?:ink|wine|coral|gold|muted)$/]",
        "message": "<ZodiacGlyph> color must be one of 'ink' | 'wine' | 'coral' | 'gold' | 'muted'."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
